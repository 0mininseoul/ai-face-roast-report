# Vertex AI Gemini
GOOGLE_CLOUD_PROJECT=gen-lang-client-0311522474
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true
VERTEX_AI_MODEL=gemini-2.5-pro
VERTEX_AI_FALLBACK_MODEL=gemini-2.5-flash
VERTEX_AI_FAST_MODEL=gemini-2.5-flash-lite

# Local only: path to the service account JSON generated under .secrets/.
GOOGLE_APPLICATION_CREDENTIALS=

# Vercel only: base64-encoded service account JSON. Do not commit real values.
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# Analysis worker queue
CRON_SECRET=
ANALYSIS_MAX_CONCURRENT=2
ANALYSIS_DRAIN_MAX_JOBS=4
ANALYSIS_DRAIN_BUDGET_MS=240000
ANALYSIS_DRAIN_MIN_NEXT_JOB_BUDGET_MS=45000
ANALYSIS_PRO_RETRY_ATTEMPTS=2
ANALYSIS_PRO_TIMEOUT_MS=75000
ANALYSIS_FALLBACK_TIMEOUT_MS=55000
ANALYSIS_FAST_TIMEOUT_MS=30000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Kakao
NEXT_PUBLIC_KAKAO_JS_KEY=

# Optional local SFX. Set to true only after public/sfx/*.mp3 exists.
NEXT_PUBLIC_ENABLE_SFX=false

# Public URL for OG / share links
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Abuse protection
IP_HASH_SALT=

# Admin report archive
ADMIN_DATA_USERNAME=
ADMIN_DATA_PASSWORD=
