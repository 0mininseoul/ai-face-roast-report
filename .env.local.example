# Gemini
GEMINI_API_KEY=
GEMINI_ANALYSIS_MODEL=gemini-2.5-pro
GEMINI_LIVE_MODEL=gemini-2.5-flash

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Kakao
NEXT_PUBLIC_KAKAO_JS_KEY=

# Optional local SFX. Set to true only after public/sfx/*.mp3 exists.
NEXT_PUBLIC_ENABLE_SFX=false

# Public URL for OG / share links
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Abuse protection
IP_HASH_SALT=
